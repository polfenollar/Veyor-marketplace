# Copy this file to .env and fill in your keys. Never commit .env.
# If .env was ever committed or leaked, rotate all API keys immediately.

# LangSmith Configuration
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=VEYOR-marketplace-agents

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# VEYOR Backend API
VEYOR_API_BASE_URL=http://localhost:8080/api
VEYOR_API_KEY=optional_if_using_jwt

# Agent Configuration
AGENT_TEMPERATURE=0.0
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=true
