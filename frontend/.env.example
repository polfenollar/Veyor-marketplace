# Copy to .env.local and set your values. Never commit .env.local.

# Backend API (required for local dev)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Flagsmith (public client ID – safe to commit in example)
NEXT_PUBLIC_FLAGSMITH_ID=your_flagsmith_environment_id

# NextAuth / Keycloak (only if using Keycloak auth – do not commit real secret)
# KEYCLOAK_CLIENT_ID=
# KEYCLOAK_CLIENT_SECRET=
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=
